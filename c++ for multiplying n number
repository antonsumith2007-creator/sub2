#include <iostream>
using namespace std;

int main() {
    int n;
    double num, product = 1;

    cout << "Enter how many numbers to multiply: ";
    cin >> n;

    for (int i = 1; i <= n; ++i) {
        cout << "Enter number " << i << ": ";
        cin >> num;
        product *= num;
    }

    cout << "Product of the " << n << " numbers is: " << product << endl;

    return 0;
}
