<!DOCTYPE html>
<html>
<head>
    <title>Country Population Adder</title>
    <style>
        body {
            font-family: Arial, sans-serif;
        }
        table {
            border-collapse: collapse;
            margin-top: 10px;
        }
        table, th, td {
            border: 1px solid black;
            padding: 8px;
        }
    </style>
</head>
<body>
    <h2>Country Population Calculator</h2>
    <form id="populationForm">
        <label for="country">Country Name:</label>
        <input type="text" id="country" required>
        <br><br>
        <label for="population">Population:</label>
        <input type="number" id="population" required>
        <br><br>
        <button type="button" onclick="addCountry()">Add Country</button>
    </form>

    <h3>Countries Added:</h3>
    <table id="countryTable">
        <tr>
            <th>Country</th>
            <th>Population</th>
        </tr>
    </table>

    <h3>Total Population: <span id="totalPopulation">0</span></h3>

    <script>
        let total = 0;

        function addCountry() {
            let country = document.getElementById("country").value;
            let population = parseInt(document.getElementById("population").value);

            if (country && !isNaN(population)) {
                // Add row to table
                let table = document.getElementById("countryTable");
                let row = table.insertRow();
                let cell1 = row.insertCell(0);
                let cell2 = row.insertCell(1);
                cell1.innerHTML = country;
                cell2.innerHTML = population;

                // Update total
                total += population;
                document.getElementById("totalPopulation").innerText = total;

                // Clear inputs
                document.getElementById("country").value = "";
                document.getElementById("population").value = "";
            } else {
                alert("Please enter valid country and population.");
            }
        }
    </script>
</body>
</html>
